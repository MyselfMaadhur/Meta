 .timeline { display: flex; overflow-x: auto; gap: 12px; padding: 16px 0; scroll-snap-type: x mandatory; }
 .timeline-item { min-width: 220px; background: #334155; padding: 16px; border-radius: 12px; border-left: 4px solid #3b82f6; scroll-snap-align: start; }
